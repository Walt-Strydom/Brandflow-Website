# Security Headers for BrandFlow Website
# Apache Server Configuration

# Enable rewrite engine
RewriteEngine On

# Clean URL redirects (remove .html)
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L]


# Redirect legacy AI advisor URL to canonical route
RewriteRule ^ai-advisor(?:\.html)?$ /automation-advisor [R=301,L,NC]

# Remove trailing slash on clean URLs (non-directories)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Serve clean URLs from .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^/.]+)$ $1.html [L]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

<IfModule mod_headers.c>
    # Encourage broad indexing/preview eligibility for crawlers and AI surfaces
    Header always set X-Robots-Tag "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"

    # Prevent Content Type Sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Strict Transport Security (HSTS) - Force HTTPS for 1 year
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # XSS Protection (legacy browsers)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy - Control information sent in Referer header
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy - Control browser features
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # Content Security Policy
    # frame-ancestors allows Google surfaces (NotebookLM, etc.) to embed/fetch page previews.
    # X-Frame-Options is intentionally omitted; frame-ancestors in CSP supersedes it.
    Header always set Content-Security-Policy "\
        default-src 'self'; \
        script-src 'self' 'unsafe-inline' blob: https://code.iconify.design https://cdnjs.cloudflare.com https://static.cloudflareinsights.com https://www.googletagmanager.com https://www.google-analytics.com; \
        style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
        font-src 'self' https://fonts.gstatic.com; \
        img-src 'self' data: blob: https://www.google-analytics.com https://www.googletagmanager.com; \
        connect-src 'self' https://formsubmit.co https://www.google-analytics.com https://www.googletagmanager.com https://api.iconify.design https://api.simplesvg.com https://cdnjs.cloudflare.com https://n8n.brandflow.co.za; \
        frame-src 'none'; \
        object-src 'none'; \
        base-uri 'self'; \
        form-action 'self' https://formsubmit.co; \
        frame-ancestors 'self' https://notebooklm.google.com https://*.google.com; \
        upgrade-insecure-requests"
</IfModule>

# Prevent directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Cache Control for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

# Compress text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>
